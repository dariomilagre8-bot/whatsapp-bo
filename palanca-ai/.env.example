# ===========================================
# Palanca AI — Variáveis de Ambiente
# Copiar para .env e preencher os valores
# ===========================================

NODE_ENV=development

# --- HTTP (Health Check — Easypanel/Docker) ---
PORT=3000

# --- Telegram (comandos admin e relatórios) ---
TELEGRAM_BOT_TOKEN=
TELEGRAM_ADMIN_CHAT_IDS=123456789

# --- Anthropic (Claude como Juiz de QA) ---
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-sonnet-4-20250514
ANTHROPIC_MAX_TOKENS=4096

# --- WhatsApp (sessão principal para fluxo de teste) ---
# whatsapp-web.js usa sessão local; Baileys alternativo pode usar credenciais
# Nenhuma variável obrigatória além do estado da sessão em disco (opcional)
WA_SESSION_PATH=./.wwebjs_auth

# --- Supabase (logs de auditoria) ---
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=
# Alternativa: SUPABASE_SERVICE_KEY=

# --- Notion (relatórios detalhados) ---
NOTION_API_KEY=
NOTION_PARENT_PAGE_ID=

# --- Limites do teste ---
TEST_SESSION_TIMEOUT_MS=300000
TEST_MAX_TURNS=50
