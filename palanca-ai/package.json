{
  "name": "palanca-ai",
  "version": "1.0.0",
  "description": "QA-as-a-Service — Sistema autónomo onde o Claude atua como testador de chatbots (Palanca AI)",
  "type": "module",
  "main": "dist/index.js",
  "scripts": {
    "build": "tsc",
    "start": "node dist/index.js",
    "dev": "tsx watch src/index.ts",
    "test": "node --experimental-vm-modules node_modules/tsx/dist/cli.mjs src/index.ts",
    "lint": "eslint src --ext .ts",
    "generate-types": "supabase gen types typescript --local -o src/types/supabase.ts"
  },
  "engines": {
    "node": ">=20.0.0"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.32.1",
    "@notionhq/client": "^2.2.15",
    "@supabase/supabase-js": "^2.45.0",
    "dotenv": "^16.4.5",
    "node-telegram-bot-api": "^0.66.0",
    "whatsapp-web.js": "^1.23.0"
  },
  "devDependencies": {
    "@types/node": "^22.9.0",
    "@types/node-telegram-bot-api": "^0.64.0",
    "supabase": "^2.78.1",
    "tsx": "^4.19.2",
    "typescript": "^5.6.3"
  }
}
