PORT=80
EVOLUTION_API_URL=https://whatsapp-evolution-api.oxuzyt.easypanel.host
EVOLUTION_API_KEY=sua_chave_aqui
EVOLUTION_INSTANCE=Zara-Teste
RECONNECT_PASSWORD=streamzone2026
# Token para página de ligação remota do Bráulio: /connect/braulio?token=...
CONNECT_TOKEN=streamzone2026
SUPABASE_URL=https://seu-projecto.supabase.co
SUPABASE_KEY=sua_chave_aqui
GEMINI_API_KEY=sua_chave_aqui
GOOGLE_SHEETS_ID=seu_sheet_id
SUPERVISOR_NUMBER=244946014060
SUPERVISOR_NUMBERS=244946014060

# ── Notificação de Reposição de Stock ──
# true = activa cron job a cada 30 min para notificar clientes da lista de espera
STOCK_NOTIFICATIONS_ENABLED=false

# ── CRM Follow-up Automático ──
# true = activa cron job diário às 10:00 (Angola) para follow-up de clientes que compraram há 30 dias
FOLLOWUP_ENABLED=false

# ── Renovação automática (lembretes + libertar perfis expirados) ──
# true = cron diário às 09:00 (Angola): 3d antes, no dia, +1d (a_verificar), +3d (libertar)
RENEWAL_ENABLED=false
RENEWAL_DAYS_BEFORE=3
RENEWAL_GRACE_DAYS=3

# ── Renovação pa_clients (engine, Supabase) — separado do RENEWAL_ENABLED (Google Sheets) ──
# true = 09:00 Luanda AVISO_3_DIAS+AVISO_DIA; 10:00 Luanda EXPIRADO + marca status=expired
RENEWAL_CRON_ENABLED=true
# Instância Evolution para enviar avisos (ex: whatssiru / ZapPrincipal)
RENEWAL_INSTANCE_NAME=ZapPrincipal
# Opcional: números a nunca contactar (CSV). Default exclui supervisor Don nos avisos.
# RENEWAL_SKIP_PHONE=244941713216
# Resumo [PA RENOVAÇÃO] após cada batch (CSV). Omitir = só ALERT_PHONE.
RENEWAL_NOTIFY_PHONES=244941713216,244946014060

# ── Billing ──
BILLING_ENABLED=false
BILLING_MULTICAIXA=
BILLING_CONTA=

# ── BullMQ Message Queue ──
# URL do Redis (ex: redis://:password@host:6379 ou rediss://:password@host:6380)
REDIS_URL=redis://:senha_aqui@redis-host:6379

# ── Alertas técnicos (watchdog [PA INFO]/[PA ALERTA], DLQ notifyDon, resumo renovação fallback) ──
# BOSS_NUMBER = Don / ops (CSV; LIDs longos são ignorados). Preferir BOSS_NUMBER; senão ALERT_PHONE.
BOSS_NUMBER=244941713216
# Instância Evolution usada para enviar alertas ao Don
ALERT_INSTANCE_NAME=ZapPrincipal
# Fallback se BOSS_NUMBER omitido — alertas de falha crítica / DLQ
ALERT_PHONE=244941713216

# ── Daily Intelligence Brief ──
DAILY_BRIEF_ENABLED=true
BRIEF_INSTANCE_NAME=ZapPrincipal

# ── Watchtower BI (extract diário + deliver semanal) ──
# true = activa cron 06h Angola (extractOnly) + sexta 18h Angola (run + deliver WhatsApp)
WATCHTOWER_ENABLED=true
# Instância Evolution para enviar resumos semanais (default: BRIEF_INSTANCE_NAME)
WATCHTOWER_INSTANCE_NAME=ZapPrincipal
# Destinatários por slug (opcional; default: BOSS_NUMBER)
# WATCHTOWER_NOTIFY_STREAMZONE=244946014060
# WATCHTOWER_NOTIFY_LUNA=244941713216
# WATCHTOWER_NOTIFY_PHONES=244941713216,244946014060
